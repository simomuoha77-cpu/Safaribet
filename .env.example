ADMIN_JWT_SECRET=change_this_admin_secret_min_64_chars

# API-Football (free: 100 req/day)
APIFOOTBALL_KEY=your_api_football_key_here

# The Odds API (real betting odds — required for actual odds to appear)
ODDS_API_KEY=your_odds_api_key_here

# football-data.org (additional fixtures/scores source — free tier, no odds)
# Get a free token at https://www.football-data.org/client/register
FOOTBALLDATA_API_KEY=your_footballdata_api_key_here

# App URL (for self-ping keep-alive on Render)
APP_URL=https://safaribet.onrender.com

# Rate limiting
MAX_REQUESTS_PER_MIN=60

# ── NEW: Wallet / Cash Out ──
CASHOUT_MARGIN=0.90

# ── NEW: Encryption (KYC data at rest) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── NEW: CAPTCHA (optional but recommended before going public) ──
# Leave blank to skip CAPTCHA checks during local testing.
# Set CAPTCHA_PROVIDER to 'hcaptcha' or 'turnstile' and provide the matching secret key.
CAPTCHA_PROVIDER=
CAPTCHA_SECRET_KEY=

