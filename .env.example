MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/betakedb
JWT_SECRET=change_this_to_a_very_long_random_string_min_64_chars
PORT=3000
NODE_ENV=production

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/mpesa/callback
MPESA_ENV=sandbox

# Admin Panel (KEEP SECRET)
ADMIN_PATH=/api/x9panel
ADMIN_UI_PATH=/x9panel
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=CHANGE_ME_use_32+_random_characters_never_reuse_never_share
# Second, independent secret required just to LOAD the admin panel page at all
# (separate from ADMIN_PASSWORD). Generate with: openssl rand -hex 24
# Access the panel via: https://yourdomain.com/x9panel?t=YOUR_ADMIN_PANEL_TOKEN
# Never link to this URL from anywhere public; bookmark it privately instead.
ADMIN_PANEL_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_24
ADMIN_JWT_SECRET=change_this_admin_secret_min_64_chars

# ══════════════════════════════════════════════════════════════════
# JUAN FOOTBALL API — single source of truth for ALL football data
# (fixtures, live scores, odds, results, leagues).
# Everything flows through this key. No other football API is used.
# ══════════════════════════════════════════════════════════════════
JUANAI_API_KEY=jsk_xxxxxxxxxxxxxxxx
JUANAI_URL=https://your-juanai-domain.com

# Casino wallet webhook secret — share this with Juan AI developer
# He must send it as x-casino-secret header on all wallet webhook calls
CASINO_WEBHOOK_SECRET=change_this_to_strong_random_secret

# How often to poll live scores in milliseconds (default: 20000 = 20s)
LIVE_POLL_MS=20000

# App URL (for self-ping keep-alive on Render)
APP_URL=https://safaribet.onrender.com

# Rate limiting
MAX_REQUESTS_PER_MIN=60

# ── SMS OTP (CommsGrid / sms.paygrid.co.ke) — used for registration phone verification ──
# Get your key from: https://sms.paygrid.co.ke/app → API Keys tab
# Your current key from the dashboard screenshot is a SANDBOX key (sk_test_...) —
# switch to a LIVE key before going to production, or OTPs won't actually send to real phones.
COMMSGRID_API_KEY=REPLACE_WITH_YOUR_COMMSGRID_API_KEY
# "CommsGrid" is the pre-approved default sender ID shown in their own docs
# examples — use this unless you've separately had a custom sender ID (e.g.
# "SafariBet") approved on your account. An unapproved sender_id will fail sends.
COMMSGRID_SENDER_ID=CommsGrid
# Confirmed from the actual CommsGrid API docs — do not add /v1/, their real path is /api/sms/send
COMMSGRID_BASE_URL=https://sms.paygrid.co.ke/api

