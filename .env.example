# Copy this to .env and fill in your values
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/betikadb
JWT_SECRET=your_super_secret_jwt_key_change_this
PORT=3000
ODDS_API_KEY=your_odds_api_key_from_the-odds-api.com
NODE_ENV=development

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/mpesa/callback
MPESA_ENV=sandbox

MPESA_SHORTCODE_TYPE=paybill

# Admin Panel (keep these SECRET)
ADMIN_PATH=/api/xpanel
ADMIN_UI_PATH=/xpanel
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=YourStrongPasswordHere123!
ADMIN_JWT_SECRET=your_admin_secret_different_from_main

# API-Football (api-sports.io) — free 100 req/day
APIFOOTBALL_KEY=your_api_football_key_here

# M-Pesa B2C (Withdrawal) — requires Safaricom approval
