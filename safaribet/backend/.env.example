# --- Server ---
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# --- Database ---
# Termux: pkg install mongodb, run `mongod --replSet rs0 --dbpath ~/data/db &`
# then `mongosh --eval "rs.initiate()"` once. A replica set (even single-node)
# is required because the wallet ledger uses multi-document transactions.
MONGODB_URI="mongodb://127.0.0.1:27017/safaribet?replicaSet=rs0"

# --- Auth ---
# Generate strong random secrets, e.g.: openssl rand -hex 32
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret

# --- M-Pesa (Safaricom Daraja) ---
# Get these from https://developer.safaricom.co.ke after creating a sandbox app.
# Switch MPESA_ENV to "production" once you have live credentials from Safaricom.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-ngrok-url/api/payments/mpesa/callback

# M-Pesa B2C (withdrawals) — requires a SEPARATE Safaricom application/approval
# beyond the STK Push sandbox app above. Leave blank until you have that.
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_RESULT_URL=https://your-ngrok-url/api/payments/mpesa/b2c-result
MPESA_B2C_TIMEOUT_URL=https://your-ngrok-url/api/payments/mpesa/b2c-result

# --- Casino Provider: Spribe ---
# Get these from your Spribe partner account manager / developer portal.
# SPRIBE_LAUNCH_BASE_URL and the exact signature scheme in src/lib/spribe.ts
# are UNVERIFIED PLACEHOLDERS — confirm against Spribe's real docs before going live.
SPRIBE_OPERATOR_KEY=
SPRIBE_SECRET=
SPRIBE_LAUNCH_BASE_URL=
